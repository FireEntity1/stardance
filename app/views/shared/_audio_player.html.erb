<div id="stardance-audio-player" class="audio-player" data-controller="audio-player" data-turbo-permanent>
  <audio
    src="<%= asset_path("fireentity - Stardance OST 1.mp3") %>"
    preload="metadata"
    loop
    data-audio-player-target="audio"></audio>

  <button
    type="button"
    class="audio-player__toggle"
    aria-label="Play Stardance audio"
    aria-pressed="false"
    data-audio-player-target="toggle"
    data-action="audio-player#toggle">
    <span class="audio-player__play-icon" aria-hidden="true"></span>
  </button>

  <div class="audio-player__panel" aria-label="Stardance audio controls">
    <span class="audio-player__title">Soundtrack</span>

    <label class="audio-player__volume">
      <span class="audio-player__sr-only">Volume</span>
      <input
        type="range"
        min="0"
        max="1"
        step="0.01"
        value="0.25"
        autocomplete="off"
        data-audio-player-target="volume"
        data-action="input->audio-player#setVolume">
    </label>
  </div>
</div>
